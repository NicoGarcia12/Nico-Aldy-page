{
  "name": "nico-aldy-page",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:gh-pages": "ng build --configuration production --base-href /Nico-Aldy-page/",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "lint": "eslint \"src/**/*.{ts,html}\" \"cypress/**/*.{js,ts}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\" \"cypress/**/*.{js,ts}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\" \"cypress/**/*.{js,ts}\" \"scripts/**/*.mjs\"",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "e2e": "cypress run",
    "test:ci": "jest --ci --runInBand --coverage",
    "e2e:smoke": "node scripts/run-e2e-smoke.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.21",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.18",
    "@eslint/js": "^9.22.0",
    "@types/jest": "^30.0.0",
    "cypress": "^13.17.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.1",
    "jiti": "^2.6.1",
    "prettier": "^3.5.3",
    "start-server-and-test": "^2.0.8",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.26.1"
  }
}
