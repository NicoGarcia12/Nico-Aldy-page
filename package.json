{
  "name": "nico-aldy-page",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:gh-pages": "ng build --configuration production --base-href /Nico-Aldy-page/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint \"src/**/*.{ts,html}\" \"cypress/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\" \"cypress/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\" \"cypress/**/*.ts\"",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "e2e": "cypress run",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "e2e:smoke": "node scripts/run-e2e-smoke.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.21",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.18",
    "@eslint/js": "^9.22.0",
    "@types/jasmine": "~5.1.0",
    "cypress": "^13.17.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.5.3",
    "start-server-and-test": "^2.0.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.26.1"
  }
}
